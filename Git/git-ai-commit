#!/usr/bin/env bash
set -euo pipefail

DO_PRINT=0

case "${1:-}" in
    --print|-p)
        DO_PRINT=1
        ;;
    --help|-h)
        cat <<'EOF'
Usage:
  git ai-commit          Generate AI commit message and open git commit editor
  git ai-commit --print  Generate AI commit message and print only
EOF
        exit 0
        ;;
    "")
        ;;
    *)
        echo "unknown option: $1" >&2
        exit 1
        ;;
esac

TMP_PROMPT="$(mktemp)"
TMP_OUTPUT="$(mktemp)"
LOG_FILE="${AI_COMMIT_LOG:-/tmp/git-ai-commit.log}"

trap 'rm -f "$TMP_PROMPT" "$TMP_OUTPUT"' EXIT

if git diff --cached --quiet; then
    echo "No staged changes." >&2
    exit 1
fi

{
    cat <<'EOF'
你是一个资深软件工程师。请根据下面 staged changes 生成中文 Git commit message。

要求：
1. 第一行简短标题
2. 必要时用 bullet list 说明
3. 不要输出 Markdown 代码块
4. 不要解释，只输出 commit message
5. conventional commit 风格
6. 标题格式类似：feat(scope): xxx / fix(scope): xxx / refactor(scope): xxx
EOF

    printf '\n--- stat ---\n'
    git diff --cached --stat

    printf '\n--- name-status ---\n'
    git diff --cached --name-status

    printf '\n--- diff ---\n'
    git diff --cached --no-ext-diff --unified=1 | head -c 6000
} > "$TMP_PROMPT"

if ! codex exec \
    --sandbox read-only \
    --ephemeral \
    --color never \
    -o "$TMP_OUTPUT" \
    - < "$TMP_PROMPT" >/dev/null 2>>"$LOG_FILE"; then
    echo "codex exec failed, see $LOG_FILE" >&2
    exit 1
fi

printf '\n' >> "$TMP_OUTPUT"

if [[ "$DO_PRINT" -eq 1 ]]; then
    cat "$TMP_OUTPUT"
else
    git commit -e -F "$TMP_OUTPUT"
fi
